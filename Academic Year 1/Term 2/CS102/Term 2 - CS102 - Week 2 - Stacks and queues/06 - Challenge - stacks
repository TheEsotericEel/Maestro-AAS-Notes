```

## 8. Real-World Applications

### Application 1: Browser History
```python
class BrowserHistory:
    def __init__(self):
        self.history = []
    
    def visit_page(self, page):
        self.history.append(page)
    
    def go_back(self):
        if self.history:
            return self.history.pop()
        return None

# Usage
browser = BrowserHistory()
browser.visit_page("home")
browser.visit_page("products")
browser.visit_page("checkout")
last_page = browser.go_back()  # Returns "checkout"
```

### Application 2: Text Editor Undo
```python
class TextEditor:
    def __init__(self):
        self.content = ""
        self.history = []
    
    def type_text(self, text):
        self.history.append(self.content)
        self.content += text
    
    def undo(self):
        if self.history:
            self.content = self.history.pop()

# Usage
editor = TextEditor()
editor.type_text("Hello ")
editor.type_text("World!")
editor.undo()  # Removes "World!"
```

