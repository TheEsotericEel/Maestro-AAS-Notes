## 9. Advanced Stack Patterns

### Pattern 1: Stack Validation
```python
def validate_stack_operations(operations):
    """Validate if sequence of operations is valid"""
    stack = []
    
    for op in operations:
        if op == "push":
            stack.append("item")
        elif op == "pop":
            if not stack:
                return False  # Invalid: pop from empty
            stack.pop()
    
    return True

# Test
valid_ops = ["push", "push", "pop", "push", "pop", "pop"]
invalid_ops = ["pop", "push", "pop"]
print(validate_stack_operations(valid_ops))   # True
print(validate_stack_operations(invalid_ops)) # False
```

### Pattern 2: Stack Reversal
```python
def reverse_with_stack(items):
    """Reverse a list using stack operations"""
    stack = []
    
    # Push all items
    for item in items:
        stack.append(item)
    
    # Pop to reverse
    reversed_items = []
    while stack:
        reversed_items.append(stack.pop())
    
    return reversed_items

# Usage
original = ["A", "B", "C", "D"]
reversed_list = reverse_with_stack(original)
print(reversed_list)  # ["D", "C", "B", "A"]
```

### Pattern 3: Minimum Stack
```python
class MinStack:
    """Stack that can return minimum element in O(1)"""
    
    def __init__(self):
        self.stack = []
        self.min_stack = []
    
    def push(self, item):
        self.stack.append(item)
        if not self.min_stack or item <= self.min_stack[-1]:
            self.min_stack.append(item)
    
    def pop(self):
        if self.stack:
            item = self.stack.pop()
            if item == self.min_stack[-1]:
                self.min_stack.pop()
            return item
        return None
    
    def get_min(self):
        return self.min_stack[-1] if self.min_stack else None

# Usage
min_stack = MinStack()
min_stack.push(5)
min_stack.push(3)
min_stack.push(7)
print(min_stack.get_min())  # 3
```

